{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI: setup-experiment test",
            "type": "debugpy",
            "request": "launch",
            "module": "prompt_autoresearch",
            "console": "integratedTerminal",
            "args": [
                "setup-experiment",
                "test"
            ]
        },
        {
            "name": "CLI: perform-experiment test --no-commit",
            "type": "debugpy",
            "request": "launch",
            "module": "prompt_autoresearch",
            "console": "integratedTerminal",
            "args": [
                "perform-experiment",
                "test",
                "--no-commit"
            ]
        },
        {
            "name": "CLI: read-journal test",
            "type": "debugpy",
            "request": "launch",
            "module": "prompt_autoresearch",
            "console": "integratedTerminal",
            "args": [
                "read-journal",
                "test"
            ]
        },
        {
            "name": "CLI: read-trial-prompt test",
            "type": "debugpy",
            "request": "launch",
            "module": "prompt_autoresearch",
            "console": "integratedTerminal",
            "args": [
                "read-trial-prompt",
                "test"
            ]
        },
        {
            "name": "CLI: update-trial-prompt test",
            "type": "debugpy",
            "request": "launch",
            "module": "prompt_autoresearch",
            "console": "integratedTerminal",
            "args": [
                "update-trial-prompt",
                "test",
                "experiments/test/trial_prompt.md"
            ]
        },
        {
            "name": "CLI: update-results test --no-commit",
            "type": "debugpy",
            "request": "launch",
            "module": "prompt_autoresearch",
            "console": "integratedTerminal",
            "args": [
                "update-results",
                "test",
                "--branch",
                "20260425_a",
                "--commit-hash",
                "abc123",
                "--hypothesis",
                "Sample hypothesis",
                "--change",
                "Sample prompt change",
                "--total-score",
                "104.5",
                "--result",
                "keep",
                "--low-scoring-result",
                "comp_01 needs more detail",
                "--low-scoring-result",
                "struct_02 needs clearer ordering",
                "--no-commit"
            ]
        },
        {
            "name": "custom args",
            "type": "debugpy",
            "request": "launch",
            "module": "prompt_autoresearch",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Integration Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "justMyCode": true,
            "args": [
                "-s",
                "tests/integration"
            ],
            "console": "integratedTerminal"
        }
    ]
}
